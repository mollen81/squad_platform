type Mutation {
    loginWithSteam(openidParamsJson: String!): AuthResponse!
}

type Query {
    # ЗАГЛУШКА
    ping: String!

    getPlayerStats(userId: String!): PlayerStats
}

type AuthResponse {
    userId: String!
    steamId: String!
    isNewUser: Boolean!
    token: String!
}

type PlayerStats {
    eloRating: Int!
    totalPlaytimeHours: Int!
    kills: Int!
    vehiclesDestroyed: Int!
    deaths: Int!
    revives: Int!
    favoriteRole: String!
}
